# PetVision Web Application - Environment Variables Configuration
# Copy this file to .env.local for local development or .env.production for production

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# AI VISION API (Z.AI GLM-4.7)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here
NEXT_PUBLIC_VISION_BASE_URL=https://api.z.ai/api/anthropic
NEXT_PUBLIC_VISION_MODEL=glm-4.7

# =============================================================================
# AUTHENTICATION
# =============================================================================
# OAuth Providers (enabled/disabled)
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true
NEXT_PUBLIC_GITHUB_OAUTH_ENABLED=true
NEXT_PUBLIC_EMAIL_AUTH_ENABLED=true

# OAuth Redirect URLs
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# Biometric Authentication (Mobile only)
NEXT_PUBLIC_ENABLE_BIOMETRICS=false
NEXT_PUBLIC_BIOMETRIC_TIMEOUT=30000

# =============================================================================
# REDIS CONFIGURATION (Optional but recommended for caching)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TTL=86400

# =============================================================================
# PDF GENERATION
# =============================================================================
# Puppeteer settings
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
PDF_CACHE_ENABLED=true
PDF_CACHE_TTL=3600000

# PDF Generation limits
PDF_MAX_PAGES=20
PDF_MAX_FILE_SIZE=10485760

# =============================================================================
# IMAGE PROCESSING
# =============================================================================
# Maximum image dimensions for processing
NEXT_PUBLIC_MAX_IMAGE_WIDTH=2048
NEXT_PUBLIC_MAX_IMAGE_HEIGHT=2048

# Image quality settings
NEXT_PUBLIC_IMAGE_QUALITY=85
NEXT_PUBLIC_MIN_IMAGE_DIMENSION=256

# =============================================================================
# RATE LIMITING
# =============================================================================
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# FEATURES
# =============================================================================
# Enable/disable specific features
NEXT_PUBLIC_ENABLE_TIMELINE=true
NEXT_PUBLIC_ENABLE_COMPARISON=true
NEXT_PUBLIC_ENABLE_PDF_EXPORT=true
NEXT_PUBLIC_ENABLE_EMAIL_SHARING=true

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Sentry for error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Enable debug mode for development
NEXT_PUBLIC_DEBUG_MODE=false

# Log levels: error, warn, info, debug
NEXT_PUBLIC_LOG_LEVEL=info

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================
# Webhook endpoints for external integrations
WEBHOOK_PDF_GENERATION_URL=
WEBHOOK_VET_RECOMMENDATIONS_URL=

# Webhook authentication
WEBHOOK_SECRET_KEY=your-webhook-secret-here
