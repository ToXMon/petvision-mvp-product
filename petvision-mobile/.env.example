# PetVision Mobile Application - Environment Variables Configuration
# Copy this file to .env for local development

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=PetVision
APP_VERSION=1.0.0

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# API ENDPOINTS
# =============================================================================
# Web application URL for API calls
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Production API URL (update when deploying)
EXPO_PUBLIC_PRODUCTION_API_URL=https://your-production-url.com/api

# =============================================================================
# AI VISION API (Z.AI GLM-4.7)
# =============================================================================
EXPO_PUBLIC_VISION_BASE_URL=https://api.z.ai/api/anthropic
EXPO_PUBLIC_VISION_MODEL=glm-4.7

# =============================================================================
# AUTHENTICATION
# =============================================================================
# OAuth Providers (enabled/disabled)
EXPO_PUBLIC_GOOGLE_OAUTH_ENABLED=true
EXPO_PUBLIC_GITHUB_OAUTH_ENABLED=true
EXPO_PUBLIC_EMAIL_AUTH_ENABLED=true

# OAuth Redirect URLs (configure in Supabase)
EXPO_PUBLIC_AUTH_REDIRECT_URL=petvision://auth/callback

# Biometric Authentication
EXPO_PUBLIC_ENABLE_BIOMETRICS=true
EXPO_PUBLIC_BIOMETRIC_TIMEOUT=30000

# =============================================================================
# IMAGE PROCESSING
# =============================================================================
# Maximum image dimensions for processing
EXPO_PUBLIC_MAX_IMAGE_WIDTH=2048
EXPO_PUBLIC_MAX_IMAGE_HEIGHT=2048

# Image quality settings
EXPO_PUBLIC_IMAGE_QUALITY=85
EXPO_PUBLIC_MIN_IMAGE_DIMENSION=256

# Image compression settings
EXPO_PUBLIC_COMPRESSION_QUALITY=0.8
EXPO_PUBLIC_COMPRESSION_FORMAT=jpeg

# =============================================================================
# CAMERA SETTINGS
# =============================================================================
# Camera permissions
EXPO_PUBLIC_CAMERA_PERMISSION_REQUIRED=true
EXPO_PUBLIC_CAMERA_PERMISSION_MESSAGE="PetVision needs camera access to scan your pet for health analysis."

# Photo library permissions
EXPO_PUBLIC_PHOTOLIBRARY_PERMISSION_REQUIRED=true
EXPO_PUBLIC_PHOTOLIBRARY_PERMISSION_MESSAGE="PetVision needs photo library access to import pet photos for analysis."

# =============================================================================
# STORAGE
# =============================================================================
# Local storage keys
EXPO_PUBLIC_STORAGE_KEY_PREFIX="@petvision:"

# Secure storage keys
EXPO_PUBLIC_SECURE_STORAGE_ENABLED=true

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_GA_TRACKING_ID=

# =============================================================================
# DEBUGGING
# =============================================================================
# Enable debug mode for development
EXPO_PUBLIC_DEBUG_MODE=false

# Log levels: error, warn, info, debug
EXPO_PUBLIC_LOG_LEVEL=info

# =============================================================================
# FEATURES
# =============================================================================
# Enable/disable specific features
EXPO_PUBLIC_ENABLE_TIMELINE=true
EXPO_PUBLIC_ENABLE_COMPARISON=true
EXPO_PUBLIC_ENABLE_PDF_EXPORT=true
EXPO_PUBLIC_ENABLE_EMAIL_SHARING=true
EXPO_PUBLIC_ENABLE_DEEP_LINKING=true

# =============================================================================
# SUPPORT
# =============================================================================
EXPO_PUBLIC_SUPPORT_EMAIL=support@petvision.app
EXPO_PUBLIC_DOCUMENTATION_URL=https://docs.petvision.app
